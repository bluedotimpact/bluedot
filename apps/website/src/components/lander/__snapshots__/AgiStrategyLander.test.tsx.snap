                  height="17"
                  viewBox="0 0 16 17"
                  width="16"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M0 8.5H16M8 0.5L8 16.5"
                    stroke="currentColor"
                    stroke-width="2"
