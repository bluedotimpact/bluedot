                class="w-full flex items-center gap-8 text-left px-8 cursor-pointer transition-all duration-300 ease py-6 hover:bg-gray-50"
                type="button"
              >
                <span
                  class="text-[18px] font-semibold leading-[125%] text-bluedot-navy flex-grow"
                >
